{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slide Generator",
  "version": "1.1.0",
  "identifier": "com.thnhmai06.slide-generator",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:65000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Slide Generator",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://github.com https://*.githubusercontent.com; connect-src 'self' ws: wss: http: https:; font-src 'self' data:; base-uri 'self'; form-action 'self'; frame-ancestors 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "../assets/images/app-icon.png",
      "../assets/images/app-icon.ico"
    ],
    "resources": [
      "resources/backend/**/*?",
      "../assets/images/**/*?"
    ],
    "category": "Utility",
    "shortDescription": "Generate presentation slides from predefined template",
    "longDescription": "SlideGenerator desktop application",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [],
      "pubkey": ""
    }
  }
}
