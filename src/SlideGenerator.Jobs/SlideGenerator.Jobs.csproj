<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<NoWarn>$(NoWarn);1591</NoWarn>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
		<EnableDefaultCompileItems>false</EnableDefaultCompileItems>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\SlideGenerator.Framework\SlideGenerator.Framework.csproj" />
		<ProjectReference Include="..\SlideGenerator.Configs\SlideGenerator.Configs.csproj" />
		<ProjectReference Include="..\SlideGenerator.Scanning\SlideGenerator.Scanning.csproj" />
		<ProjectReference Include="..\SlideGenerator.Generating\SlideGenerator.Generating.csproj" />
		<PackageReference Include="Elsa.Workflows.Runtime" Version="3.5.3" />
		<PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.8" />
		<PackageReference Include="Serilog.Sinks.File" Version="7.0.0" />
		<PackageReference Include="Downloader" Version="4.0.3" />
	</ItemGroup>

	<ItemGroup>
	  <Compile Include="*.cs" />
	  <Compile Include="Entities\**\*.cs" />
	</ItemGroup>

</Project>
