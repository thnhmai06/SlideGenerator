<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<NoWarn>$(NoWarn);1591</NoWarn>
		<PackageLicenseExpression>GPL-3.0-only</PackageLicenseExpression>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\SlideGenerator.Framework\SlideGenerator.Framework.csproj" />
		<ProjectReference Include="..\SlideGenerator.Features\SlideGenerator.Features.csproj" />
	</ItemGroup>
	<ItemGroup Condition="'$(RuntimeIdentifier)'=='win-x64'">
		<PackageReference Include="OpenCvSharp4.runtime.win" Version="4.13.0.20260228" />
	</ItemGroup>
	<ItemGroup Condition="'$(RuntimeIdentifier)'=='linux-x64'">
		<PackageReference Include="OpenCvSharp4.runtime.ubuntu.22.04-x64" Version="4.13.0.20260228" />
	</ItemGroup>

</Project>
